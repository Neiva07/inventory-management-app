{
  "name": "stockify-app",
  "productName": "Stockify App",
  "version": "0.0.43",
  "packageManager": "pnpm@10.28.2",
  "repository": "git@github.com:Neiva07/inventory-management-app.git",
  "description": "Stockify Application for Inventory Management",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "prepublish": "rimraf out dist",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:local": "ts-node scripts/dbMigrate.ts",
    "verify:core-flows": "NODE_PATH=./src ts-node scripts/verifyCoreFlows.ts",
    "verify:offline-sync": "NODE_PATH=./src ts-node scripts/verifyOfflineSync.ts",
    "verify:migration": "pnpm run verify:core-flows && pnpm run verify:offline-sync",
    "update-db": "ts-node scripts/updateDb.ts",
    "delete-onboarding-sessions": "ts-node scripts/deleteOnboardingSessions.ts"
  },
  "keywords": [],
  "author": "lucasneiva",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "css-loader": "^6.0.0",
    "drizzle-kit": "^0.31.4",
    "electron": "40.6.0",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.25.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "node-loader": "^2.0.0",
    "postcss": "8.5.6",
    "postcss-loader": "8.2.1",
    "shadcn": "3.8.5",
    "style-loader": "^3.0.0",
    "tailwindcss": "4.2.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.31.1",
    "@hookform/resolvers": "^3.1.1",
    "@libsql/client": "^0.15.15",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@types/uuid": "^9.0.1",
    "axios": "^1.7.9",
    "babel-plugin-module-resolver": "^5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "^2.30.0",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.6",
    "electron-squirrel-startup": "^1.0.0",
    "electron-updater": "^6.6.2",
    "install": "^0.13.0",
    "lucide-react": "0.575.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.44.3",
    "react-router-dom": "^6.11.2",
    "react-text-mask": "^5.5.0",
    "react-toastify": "^9.1.3",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "update-electron-app": "^3.1.1",
    "uuid": "^9.0.0",
    "yup": "^1.2.0"
  },
  "devContentSecurityPolicy": "default-src * self blob: data: gap:; style-src * self 'unsafe-inline' blob: data: gap:; script-src * 'self' 'unsafe-eval' 'unsafe-inline' blob: data: gap:; object-src * 'self' blob: data: gap:; img-src * self 'unsafe-inline' blob: data: gap:; connect-src self * 'unsafe-inline' blob: data: gap:; frame-src * self blob: data: gap:;",
  "plugins": [
    {
      "name": "@electron-forge/plugin-webpack",
      "config": {
        "mainConfig": "./webpack.main.config.ts",
        "devContentSecurityPolicy": "connect-src 'self' https://firestore.googleapis.com/ 'unsafe-eval'",
        "renderer": {
          "config": "./webpack.renderer.config.ts",
          "entryPoints": [
            {
              "html": "./src/index.ts",
              "js": "./src/renderer.ts",
              "name": "main_window"
            }
          ]
        }
      }
    }
  ]
}
